// ── Exhibition Lead Capture Platform ──────
// Full database schema with 13 tables

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // transaction pooler (6543) — app runtime
  directUrl = env("DIRECT_URL")   // session pooler (5432) — migrations / db push / seed
}

// ═══════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

enum EventStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  TEXTAREA
  DROPDOWN
  RADIO
  CHECKBOX
  DATE
  MULTI_SELECT
  FILE_UPLOAD
  URL
}

enum LeadSource {
  QR_SCAN
  OCR_SCAN
  MANUAL
}

enum LeadStatus {
  NEW
  SYNCED
  FAILED
  RETRYING
}

enum SyncTarget {
  CRM
  GOOGLE_SHEETS
}

enum SyncStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CrmAuthType {
  NONE
  API_KEY
  BEARER
  BASIC
  CUSTOM
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  SLACK
  WEBHOOK
}

// ═══════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  role          UserRole @default(STAFF)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  events        Event[]  @relation("EventCreator")
  leads         Lead[]   @relation("LeadSubmittedBy")
  auditLogs     AuditLog[]

  @@map("users")
}

model Event {
  id            String      @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  organizer     String
  venue         String
  city          String
  country       String
  startDate     DateTime    @map("start_date")
  endDate       DateTime    @map("end_date")
  status        EventStatus @default(DRAFT)
  bannerImageUrl String?    @map("banner_image_url")
  logoUrl       String?     @map("logo_url")
  createdBy     String      @map("created_by") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // Relations
  creator          User               @relation("EventCreator", fields: [createdBy], references: [id])
  booths           Booth[]
  visitorTypes     VisitorType[]
  formDefinitions  FormDefinition[]
  crmConfigurations CrmConfiguration[]
  leads            Lead[]
  qrCodes          QrCode[]
  sheetsConfig     GoogleSheetsConfig?
  notificationConfigs NotificationConfig[]

  @@index([status])
  @@index([createdBy])
  @@map("events")
}

model Booth {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  name          String
  description   String?
  locationHint  String?  @map("location_hint")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leads     Lead[]
  qrCodes   QrCode[]

  @@index([eventId])
  @@map("booths")
}

model QrCode {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  boothId       String   @map("booth_id") @db.Uuid
  visitorTypeId String   @map("visitor_type_id") @db.Uuid
  shortCode     String   @unique @map("short_code")
  label         String?
  isActive      Boolean  @default(true) @map("is_active")
  scanCount     Int      @default(0) @map("scan_count")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  booth       Booth       @relation(fields: [boothId], references: [id], onDelete: Cascade)
  visitorType VisitorType @relation(fields: [visitorTypeId], references: [id], onDelete: Cascade)

  @@index([shortCode])
  @@index([eventId])
  @@index([boothId])
  @@map("qr_codes")
}

model VisitorType {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  name          String
  slug          String
  color         String?
  isActive      Boolean  @default(true) @map("is_active")
  displayOrder  Int      @default(0) @map("display_order")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leads   Lead[]
  qrCodes QrCode[]

  @@unique([eventId, slug])
  @@index([eventId])
  @@map("visitor_types")
}

model FormDefinition {
  id            String   @id @default(uuid()) @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  name          String
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  event   Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fields  FormField[]
  leads   Lead[]

  @@index([eventId])
  @@map("form_definitions")
}

model FormField {
  id                  String   @id @default(uuid()) @db.Uuid
  formDefinitionId    String   @map("form_definition_id") @db.Uuid
  fieldKey            String   @map("field_key")
  fieldType           FieldType @map("field_type")
  label               String
  placeholder         String?
  helpText            String?  @map("help_text")
  isRequired          Boolean  @default(false) @map("is_required")
  defaultValue        Json?    @map("default_value")
  validationRules     Json?    @map("validation_rules")
  displayOrder        Int      @default(0) @map("display_order")
  isActive            Boolean  @default(true) @map("is_active")
  conditionalRules    Json?    @map("conditional_rules")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relations
  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id], onDelete: Cascade)
  options        FieldOption[]

  @@unique([formDefinitionId, fieldKey])
  @@index([formDefinitionId])
  @@map("form_fields")
}

model FieldOption {
  id            String   @id @default(uuid()) @db.Uuid
  formFieldId   String   @map("form_field_id") @db.Uuid
  label         String
  value         String
  displayOrder  Int      @default(0) @map("display_order")
  isDefault     Boolean  @default(false) @map("is_default")

  // Relations
  formField FormField @relation(fields: [formFieldId], references: [id], onDelete: Cascade)

  @@index([formFieldId])
  @@map("field_options")
}

model Lead {
  id                  String     @id @default(uuid()) @db.Uuid
  eventId             String     @map("event_id") @db.Uuid
  boothId             String     @map("booth_id") @db.Uuid
  visitorTypeId       String     @map("visitor_type_id") @db.Uuid
  formDefinitionId    String     @map("form_definition_id") @db.Uuid
  source              LeadSource
  submittedBy         String?    @map("submitted_by") @db.Uuid
  rawFormData         Json       @map("raw_form_data")
  ocrRawText          String?    @map("ocr_raw_text") @db.Text
  ocrConfidence       Float?     @map("ocr_confidence")
  crmSynced           Boolean    @default(false) @map("crm_synced")
  crmResponse         Json?      @map("crm_response")
  sheetsSynced        Boolean    @default(false) @map("sheets_synced")
  status              LeadStatus @default(NEW)
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  // Relations
  event          Event          @relation(fields: [eventId], references: [id])
  booth          Booth          @relation(fields: [boothId], references: [id])
  visitorType    VisitorType    @relation(fields: [visitorTypeId], references: [id])
  formDefinition FormDefinition @relation(fields: [formDefinitionId], references: [id])
  submittedByUser User?         @relation("LeadSubmittedBy", fields: [submittedBy], references: [id])
  syncQueue      SyncQueue[]
  syncLogs       SyncLog[]

  @@index([eventId])
  @@index([boothId])
  @@index([visitorTypeId])
  @@index([status])
  @@index([createdAt])
  @@index([source])
  @@map("leads")
}

model CrmConfiguration {
  id                    String     @id @default(uuid()) @db.Uuid
  eventId               String     @map("event_id") @db.Uuid
  apiUrl                String     @map("api_url")
  method                HttpMethod @default(POST)
  headers               Json?
  authType              CrmAuthType @default(NONE) @map("auth_type")
  authCredentials       Json?      @map("auth_credentials")
  payloadMapping        Json       @map("payload_mapping")
  successResponsePattern Json?     @map("success_response_pattern")
  failureResponsePattern Json?     @map("failure_response_pattern")
  timeoutMs             Int        @default(10000) @map("timeout_ms")
  isActive              Boolean    @default(true) @map("is_active")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("crm_configurations")
}

model SyncQueue {
  id            String     @id @default(uuid()) @db.Uuid
  leadId        String     @map("lead_id") @db.Uuid
  target        SyncTarget
  attemptCount  Int        @default(0) @map("attempt_count")
  maxAttempts   Int        @default(5) @map("max_attempts")
  nextRetryAt   DateTime?  @map("next_retry_at")
  status        SyncStatus @default(PENDING)
  lastError     String?    @map("last_error") @db.Text
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@index([leadId])
  @@map("sync_queue")
}

model SyncLog {
  id             String     @id @default(uuid()) @db.Uuid
  leadId         String     @map("lead_id") @db.Uuid
  target         SyncTarget
  status         String     // "SUCCESS" | "FAILURE"
  requestPayload Json?      @map("request_payload")
  responsePayload Json?     @map("response_payload")
  httpStatusCode Int?       @map("http_status_code")
  durationMs     Int?       @map("duration_ms")
  createdAt      DateTime   @default(now()) @map("created_at")

  // Relations
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([createdAt])
  @@map("sync_logs")
}

model GoogleSheetsConfig {
  id                         String   @id @default(uuid()) @db.Uuid
  eventId                    String   @unique @map("event_id") @db.Uuid
  spreadsheetId              String   @map("spreadsheet_id")
  worksheetName              String   @map("worksheet_name")
  columnMapping              Json     @map("column_mapping")
  serviceAccountCredentials  Json?    @map("service_account_credentials")
  isActive                   Boolean  @default(true) @map("is_active")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("google_sheets_config")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model NotificationConfig {
  id        String              @id @default(uuid()) @db.Uuid
  eventId   String              @map("event_id") @db.Uuid
  channel   NotificationChannel
  isActive  Boolean             @default(true) @map("is_active")
  config    Json
  events    Json                // which events trigger notifications
  createdAt DateTime            @default(now()) @map("created_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("notification_configs")
}
