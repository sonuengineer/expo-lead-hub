# ── Server ──────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (Supabase PostgreSQL) ─────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/elc_dev?schema=public

# ── JWT ─────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Google Cloud Vision OCR ────────────────
GOOGLE_APPLICATION_CREDENTIALS=
# Or set individual keys:
GOOGLE_VISION_PROJECT_ID=

# ── Google Sheets ──────────────────────────
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# ── CORS ───────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Encryption ─────────────────────────────
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# ── WhatsApp (OpenWA self-hosted gateway) ──
# Spin up the `openwa` compose service, create a session + API key in its
# dashboard (http://localhost:2785), then paste the key below.
OPENWA_BASE_URL=http://localhost:2785
OPENWA_API_KEY=
OPENWA_SESSION_ID=default

# ── Email ──
# Option A (recommended): Resend HTTP API. Create a key at resend.com and use a
# From address on your verified domain. No SMTP ports needed.
RESEND_API_KEY=
EMAIL_FROM="Rathinfotech <seo@rathinfotech.com>"
# Option B (fallback): raw SMTP. Only used when RESEND_API_KEY is empty.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
